DATABASE_URL=
PORT=3001
WOOCOMMERCE_URL=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=
ENCRYPT_SECRET=
OPENAI_API_KEY=

# REQUIRED for invite-only sign-up.
# Clerk Backend API secret key (use the sk_live_... key for production, the one
# that matches the pk_live_ publishable key on the frontend). Without it the
# server cannot mint invitation tickets, so invited users CANNOT sign up while
# Clerk Sign-up Mode is "Restricted".
CLERK_SECRET_KEY=

# Public URL of the deployed frontend. Used to build invitation links and the
# post-sign-up redirect. Must be the real site, e.g. https://www.gems-dna.com
FRONTEND_URL=https://www.gems-dna.com

# Resend API key — used to send the branded team-invite emails.
RESEND_API_KEY=
