{
    "version": 2,
    "functions": {
      "api/stones/server.js": {
        "maxDuration": 60,
        "memory": 1024
      }
    },
    "builds": [
      {
        "src": "api/stones/server.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/api/image-proxy",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/import-csv(.*)",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/sync/preview",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/sync",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/soap-stones",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/tags",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/tags/(.*)",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/stone-tags",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/saved-filters",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/saved-filters/(.*)",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/label-templates/set-active/(.*)",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/label-templates/(.*)",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/label-templates",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/stones",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/stones/(.*)",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/crm/stats",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/crm/contacts",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/crm/contacts/(.*)",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/crm/interactions",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/crm/interactions/(.*)",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/crm/deals",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/crm/deals/(.*)",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/crm/deal-items/(.*)",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/crm/tasks",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/crm/tasks/(.*)",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/crm/whatsapp-log",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/crm/scan-card",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/crm/verify-business",
        "dest": "api/stones/server.js"
      },
      {
        "src": "/api/crm/tags",
        "dest": "api/stones/server.js"
      }
    ]
  }
  